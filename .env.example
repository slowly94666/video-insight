# ═══════════════════════════════════════════
# Video Insight — 环境变量模板
# 复制为 .env 后填入你的 API Key
#   cp .env.example .env
# ═══════════════════════════════════════════

# ── LLM 提供商（大模型，用于分析报告） ──
# 可选: deepseek / openai / custom
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=sk-你的DeepSeekKey

# OpenAI（LLM_PROVIDER=openai 时生效）
# OPENAI_API_KEY=sk-你的OpenAIKey

# 自定义 API（LLM_PROVIDER=custom 时生效）
# CUSTOM_API_KEY=你的Key
# CUSTOM_BASE_URL=https://你的API地址/v1
# CUSTOM_MODEL=你的模型名

# ── ASR 引擎（语音转文字） ──
# 默认: siliconflow（国内直连，推荐）
# 可选: groq / gemini / whisper

# SiliconFlow SenseVoice（推荐，国内直连无需代理）
SILICONFLOW_API_KEY=sk-你的SiliconFlowKey

# Groq Whisper（需代理）
# GROQ_API_KEY=gsk_你的GroqKey
# GROQ_ASR_MODEL=whisper-large-v3-turbo

# Gemini（不稳定，备用）
# GEMINI_API_KEY=你的GeminiKey
# GEMINI_ASR_MODEL=gemini-2.5-flash-lite

# MiMo（旧，Key 可能已过期）
# API_KEY=tp-你原有的MiMoKey